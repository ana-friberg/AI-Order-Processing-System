# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# ── Flask API Auth ────────────────────────────────────────────────────────────
AUTHORIZATION_USERNAME=1234...
AUTHORIZATION_PASSWORD=ABC...

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY_AGILENT = sk-ant-api...
# ── Priority ERP ──────────────────────────────────────────────────────────────
PRIORITY_URL=https://priority...
PRIORITY_TOKEN=1234..
PRIORITY_MAIN_SCREEN=ABC...
PRIORITY_MAIN_SUB_SCREEN=ABC_SUBFORM...

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI_AGILENT = mongodb+srv://1234:ABC...
MONGODB_DBNAME_AGILENT=agilent_orders
MONGODB_COLLECTION_AGILENT=order_responses
